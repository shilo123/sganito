    <script type="text/javascript">


        var UserId = "<%=UserId%>";
        var RoleId = "<%=RoleId%>";
        var UserName = "<%=UserName%>";

        var ConfigurationId = "<%=ConfigurationId%>";
        var HebDate = "<%=HebDate%>";
        var Name = "<%=Name%>";
        var SchoolId = "<%=SchoolId%>";

        
        $(document).ready(function () {


            



            if (!UserId)
                location.href = '../Login.aspx';

          
            $("#spUserName").text(UserName);
            $("#dvCurrentSchoolName").html(Name);
            $("#dvCurrentYearName").html(HebDate);

            

            var href = $(location).attr('href');
           

            var locName = ".." + location.pathname.replace("Sganit", "").substring(1);
            $('a[href="' + locName + '"]').addClass("active");


            var imgsrc = "../assets/images/SchoolLogo/" + SchoolId + "_.png";
           

            $("#imgLogo").prop("src", imgsrc);
            $('#imgLogo').error(function () {
                $("#imgLogo").prop("src", "../assets/images/demo/avatar-80.png");
            });



            $("body").show();
            UpdateClassStatus();
          


           


        });



        //function OpenAssignment(Obj) {
