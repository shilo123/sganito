        //    setCookie("OrgUnitName", $.trim(OrgUnitName), 2147483647);


        //    location.href = '../Assign/Assignment.aspx';

        //}


        function ExistSystem() {
            location.href = '../Login.aspx';
        }

        function UpdateClassStatus() {
            $("#ulAreas").html("");
            var Data = Ajax("Class_GetClassStatus");

            for (var i = 0; i < Data.length; i++) {


                var HourSchool = Data[i].HourSchool;
                var ClassHour = Data[i].ClassHour;
                var ClassName=  Data[i].ClassName;
                var buttonClass = "ls-red-btn";
                if (ClassHour == HourSchool) {
                    buttonClass = "btn-success";
                } else {
                    if (IsNullDB(Data[i].ClassId))
                         IsOk = false;

                }
                var obj = "<li><button style='padding-right:10px;padding-left:10px' class='btn " + buttonClass + " btn-round btn-xs btnArea'>" + ClassName + "</button> </li>";

                $("#ulAreas").append(obj);
            }

           
                              
                      

        }
     

        
    </script>
    <asp:ContentPlaceHolder ID="head" runat="server">
    </asp:ContentPlaceHolder>
